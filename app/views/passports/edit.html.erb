<div class="container my-4">
  <div class="d-flex justify-content-end mb-2">
    <%= link_to "Retour", passports_path, class: "btn btn-secondary me-2" %>
    <%= button_to "Supprimer", @passport, method: :delete, data: { confirm: "Es-tu sûr de vouloir supprimer ce passeport ?" }, class: "btn btn-danger" %>
  </div>

  <h1 class="text-center mb-4">Modifier le passeport</h1>

  <div class="d-flex justify-content-center">
    <div class="card shadow w-100" style="max-width: 960px;">
      <div class="card-body">
        <%= render 'form', passport: @passport %>
      </div>
    </div>
  </div>
</div>